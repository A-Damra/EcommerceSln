@page "/Categories"

<h3 class="m-3">Categories</h3>

<link rel="stylesheet" href="css/GeneralElements.css" />
<div class="container dark-bg mt-2 p-4 rounded-4">
    <div class="row mb-3">
        <div class="col">
            <button class="btn-header" @onclick="ShowList">List Categories</button>
            <button class="btn-header" @onclick="HideList">Create New</button>
        </div>
    </div>

    <div class="row">
        <div class="col">
            <hr class="spliter" />
        </div>
    </div>

    @if (IsList)
    {
        <CategoriesList />
    }
    else
    {
        <AddCategory />
    }
</div>

@code {
    public bool IsList = true;

    public void ShowList()
    {
        IsList = true;
    }

    public void HideList()
    {
        IsList = false;
    }
}
