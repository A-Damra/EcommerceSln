@*
    create, edit IsActive in c# is bool and in the db is tinyint(1)
*@

@page "/CategoriesList"
@using Ecommerce.Domain.Entities

<link rel="stylesheet" href="css/GeneralElements.css" />

<h3 class="m-3">Categories</h3>

<div class="container">
    <div class="row mb-3">
        <div class="col">
            <button class="btn-header">List Categories</button>
            <button class="btn-header">Create New</button>
        </div>
    </div>

    <div class="row">
        <div class="col">
            <hr style="color:#aaaa9e;" />
        </div>
    </div>

    <div class="row g-2">
        <div class="col">
            <input class="form-control search-bar" placeholder="Search Categories..." />
        </div>
        <div class="col-auto">
            <button class="btn-header">Search</button>
        </div>
    </div>

    <div class="row">
        <div class="col">
            <table class="table mt-4 text-center align-middle">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        @foreach (var cat in categories)
                        {
                            <td>@cat.Name</td>
                            <td>
                                <span class="badge p-2 @(cat.IsActive ? "active" : "inactive")">@cat.IsActive</span>
                            </td>
                            <td>
                                <button class="btn-detail">Edit</button>
                                <button class="btn-detail">Delete</button>
                            </td>
                        }
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private List<Categories> categories = new List<Categories>();

    protected async override Task OnInitializedAsync()
    {
        categories = await ApiClient.GetAsync<List<Categories>>("api/categories") ?? new List<Categories>();
    }
}
